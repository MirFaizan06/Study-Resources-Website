generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
  CONTRIBUTOR
}

enum InstitutionType {
  UNIVERSITY
  COLLEGE
  SCHOOL
}

enum ResourceType {
  NOTE
  PYQ
  SYLLABUS
  GUESS_PAPER
}

enum RequestStatus {
  PENDING
  FULFILLED
}

enum SubjectCategory {
  MAJOR
  MINOR
  MD
  AEC
  VAC
  SEC
}

enum PostStatus {
  ACTIVE
  REMOVED
}

enum PostCategory {
  ACADEMICS
  INFRASTRUCTURE
  ADMINISTRATION
  TRANSPORT
  HOSTEL
  SPORTS_CULTURE
  OTHER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  role            Role             @default(STUDENT)
  passwordHash    String
  university      String?
  college         String?
  semester        Int?
  profilePicUrl   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  resources       Resource[]
  concernPosts    ConcernPost[]
  concernVotes    ConcernVote[]
  concernComments ConcernComment[]
  commentVotes    CommentVote[]
}

model Institution {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique @db.VarChar(255)
  type      InstitutionType
  logoUrl   String?
  createdAt DateTime        @default(now())
  programs  Program[]

  @@index([slug])
}

model Program {
  id            String      @id @default(cuid())
  name          String
  institutionId String
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  subjects      Subject[]

  @@index([institutionId])
}

model Subject {
  id        String           @id @default(cuid())
  name      String
  programId String
  semester  Int
  category  SubjectCategory?
  createdAt DateTime         @default(now())
  program   Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  resources Resource[]

  @@index([programId])
  @@index([category])
}

model Resource {
  id             String       @id @default(cuid())
  title          String
  type           ResourceType
  fileUrl        String
  subjectId      String
  uploaderId     String?
  downloadsCount Int          @default(0)
  isApproved     Boolean      @default(false)
  isAiGenerated  Boolean      @default(false)
  year           Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploader       User?        @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([subjectId])
  @@index([type])
  @@index([isApproved])
  @@index([createdAt])
}

model Request {
  id                String        @id @default(cuid())
  studentName       String
  requestedMaterial String        @db.Text
  contactEmail      String?
  status            RequestStatus @default(PENDING)
  createdAt         DateTime      @default(now())

  @@index([status])
}

// ─── Concerns Board ───────────────────────────────────────────────────────────

model ConcernPost {
  id           String           @id @default(cuid())
  title        String           @db.VarChar(255)
  description  String?          @db.Text
  imageUrl     String
  category     PostCategory     @default(OTHER)
  status       PostStatus       @default(ACTIVE)
  upvotesCount Int              @default(0)
  authorId     String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  author       User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes        ConcernVote[]
  comments     ConcernComment[]

  @@index([status])
  @@index([createdAt])
  @@index([upvotesCount])
  @@index([authorId])
  @@index([category])
}

model ConcernVote {
  id        String      @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime    @default(now())
  post      ConcernPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model ConcernComment {
  id           String      @id @default(cuid())
  content      String      @db.Text
  postId       String
  authorId     String
  status       PostStatus  @default(ACTIVE)
  upvotesCount Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  post         ConcernPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes        CommentVote[]

  @@index([postId])
  @@index([authorId])
  @@index([status])
}

model CommentVote {
  id        String         @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime       @default(now())
  comment   ConcernComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}
